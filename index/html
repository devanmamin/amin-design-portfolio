<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --bg: #FAFAF7;
    --ink: #1A1A1A;
    --muted: #6B6B6B;
    --line: rgba(0,0,0,0.1);
    --accent: #2A3557;       /* Change to make it yours. Suggested: a single brand color. */
    --max-w: 1080px;
    --gap: clamp(24px, 5vw, 64px);
  }

  html { scroll-behavior: smooth; }
  body {
    font-family: 'Inter', -apple-system, sans-serif;
    background: var(--bg);
    color: var(--ink);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    font-size: 17px;
  }

  a { color: inherit; text-decoration: none; }
  a:hover { opacity: 0.65; }

  h1, h2, h3 { font-family: 'Fraunces', Georgia, serif; font-weight: 600; line-height: 1.1; letter-spacing: -0.01em; }
  h1 { font-size: clamp(40px, 6vw, 72px); }
  h2 { font-size: clamp(28px, 4vw, 44px); margin-bottom: 24px; }
  h3 { font-size: clamp(20px, 2.5vw, 28px); margin-bottom: 12px; }

  p { margin-bottom: 16px; }
  p:last-child { margin-bottom: 0; }

  .wrap { max-width: var(--max-w); margin: 0 auto; padding: 0 24px; }

  /* ── Nav ───────────────────────────────────────────────────── */
  nav {
    position: sticky; top: 0; z-index: 10;
    background: rgba(250,250,247,0.92); backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--line);
  }
  nav .wrap {
    display: flex; justify-content: space-between; align-items: center;
    padding-top: 18px; padding-bottom: 18px;
  }
  nav .brand { font-weight: 600; font-size: 16px; }
  nav .links { display: flex; gap: 28px; font-size: 14px; }

  /* ── Hero ──────────────────────────────────────────────────── */
  .hero { padding: clamp(80px, 14vw, 160px) 0 clamp(60px, 10vw, 120px); }
  .hero .hook { font-family: 'Fraunces', serif; font-size: clamp(40px, 7vw, 88px); line-height: 1.05; margin-bottom: 32px; max-width: 900px; }
  .hero .hook em { font-style: italic; color: var(--accent); }
  .hero .bio { font-size: clamp(18px, 2vw, 22px); max-width: 620px; color: var(--muted); line-height: 1.55; }

  /* ── Sections ──────────────────────────────────────────────── */
  section { padding: clamp(60px, 9vw, 120px) 0; border-top: 1px solid var(--line); }
  section .section-label { font-size: 12px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); margin-bottom: 24px; }

  /* ── Work grid ─────────────────────────────────────────────── */
  .work-grid { display: grid; gap: clamp(32px, 5vw, 56px); }
  .case-card {
    display: grid; grid-template-columns: 1fr 1fr; gap: var(--gap); align-items: center;
    padding: clamp(24px, 4vw, 48px) 0;
  }
  .case-card:nth-child(even) .case-img { order: 2; }
  .case-img {
    aspect-ratio: 4 / 3; background: #EAEAE3 center/cover no-repeat; border-radius: 8px;
    display: flex; align-items: center; justify-content: center; color: var(--muted); font-size: 13px;
  }
  .case-text .case-tag { font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); margin-bottom: 12px; }
  .case-text h3 { margin-bottom: 16px; }
  .case-text .case-line { font-size: 17px; line-height: 1.55; color: var(--muted); margin-bottom: 20px; }
  .case-text .case-link { font-size: 14px; font-weight: 500; border-bottom: 1.5px solid currentColor; padding-bottom: 2px; }

  /* ── Case study page-within-page ───────────────────────────── */
  .case-study {
    padding: clamp(48px, 8vw, 96px) 0; border-top: 1px solid var(--line);
  }
  .case-study .cs-meta {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 24px; padding: 24px 0; margin-bottom: 40px;
    border-top: 1px solid var(--line); border-bottom: 1px solid var(--line);
  }
  .case-study .cs-meta div { font-size: 13px; }
  .case-study .cs-meta strong { display: block; font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); margin-bottom: 4px; }
  .case-study .cs-block { margin-bottom: 48px; max-width: 720px; }
  .case-study .cs-block h3 { margin-bottom: 16px; }
  .case-study .cs-figure { margin: 32px 0; }
  .case-study .cs-figure img, .case-study .cs-figure .cs-figure-placeholder {
    width: 100%; aspect-ratio: 16 / 9; background: #EAEAE3; border-radius: 6px;
    display: flex; align-items: center; justify-content: center; color: var(--muted); font-size: 13px;
  }
  /* Embedded media (video, iframes, PDF objects) fit the figure slot cleanly */
  .case-study .cs-figure iframe,
  .case-study .cs-figure video,
  .case-study .cs-figure embed,
  .case-study .cs-figure object {
    width: 100%; aspect-ratio: 16 / 9; border-radius: 6px; border: 0; display: block; background: #1A1A1A;
  }
  .case-study .cs-figure object[type="application/pdf"],
  .case-study .cs-figure embed[type="application/pdf"] {
    aspect-ratio: 3 / 4; min-height: 480px; background: #EAEAE3;
  }
  .case-study .cs-figure figcaption { font-size: 13px; color: var(--muted); margin-top: 10px; }
  .case-study .cs-outcome {
    background: #fff; border: 1px solid var(--line); border-radius: 8px;
    padding: 32px; margin-top: 32px;
  }
  .case-study .cs-outcome h4 { font-family: 'Fraunces', serif; font-size: 22px; margin-bottom: 12px; }

  /* ── About ─────────────────────────────────────────────────── */
  .about-grid { display: grid; grid-template-columns: 1fr 2fr; gap: var(--gap); align-items: start; }
  .about-photo {
    aspect-ratio: 4 / 5; background: #EAEAE3; border-radius: 8px;
    display: flex; align-items: center; justify-content: center; color: var(--muted); font-size: 13px;
  }
  .about-text p { font-size: 17px; line-height: 1.65; margin-bottom: 16px; }

  /* ── Inspiration Collection (Dear Data form) ───────────────── */
  .inspiration {
    display: grid; grid-template-columns: 1fr 1fr; gap: var(--gap); align-items: center;
  }
  .inspiration .insp-placeholder {
    width: 100%; aspect-ratio: 4 / 5; background: #EAEAE3 center/cover no-repeat; border-radius: 8px;
    display: flex; align-items: center; justify-content: center; color: var(--muted); font-size: 13px;
  }
  .inspiration img {
    width: 100%; height: auto; aspect-ratio: auto; object-fit: contain;
    border-radius: 8px; display: block;
  }
  .inspiration .insp-text p { color: var(--muted); }
  .inspiration .insp-legend { margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--line); font-size: 14px; color: var(--muted); }
  .inspiration-table { width: 100%; border-collapse: collapse; margin-top: 24px; font-size: 14px; }
  .inspiration-table th, .inspiration-table td { border: 1px solid var(--line); padding: 10px 12px; text-align: left; vertical-align: top; }
  .inspiration-table th { background: rgba(0,0,0,0.04); font-weight: 600; font-size: 13px; text-transform: uppercase; letter-spacing: 0.04em; color: var(--muted); }
  .inspiration-table td.num { text-align: center; width: 36px; opacity: 0.5; font-variant-numeric: tabular-nums; }
  .inspiration-table td.seminal { text-align: center; white-space: nowrap; font-family: 'Inter', sans-serif; font-weight: 600; letter-spacing: 0.05em; }
  .inspiration-side-label { font-family: 'Fraunces', serif; font-size: 18px; font-weight: 600; margin: 32px 0 8px; color: var(--ink); }
  .inspiration-side-label small { font-weight: 400; font-size: 13px; color: var(--muted); margin-left: 8px; font-family: 'Inter', sans-serif; letter-spacing: 0.04em; text-transform: uppercase; }

  /* Concept-tag reference (collapsible) */
  .concept-ref {
    margin: 12px 0 24px; border: 1px solid var(--line); border-radius: 6px;
    padding: 0 16px; background: rgba(0,0,0,0.02);
  }
  .concept-ref summary {
    cursor: pointer; font-weight: 600; font-size: 14px; padding: 14px 0;
    user-select: none; list-style: none; position: relative; padding-left: 22px;
  }
  .concept-ref summary::before {
    content: '▸'; position: absolute; left: 4px; top: 14px; font-size: 12px;
    color: var(--muted); transition: transform 0.15s;
  }
  .concept-ref[open] summary::before { transform: rotate(90deg); }
  .concept-ref summary::-webkit-details-marker { display: none; }
  .concept-ref h4 {
    font-family: 'Fraunces', serif; font-size: 16px; font-weight: 600;
    margin: 16px 0 8px; color: var(--ink);
  }
  .concept-ref dl {
    display: grid; grid-template-columns: minmax(160px, max-content) 1fr;
    gap: 6px 18px; font-size: 13px; margin: 4px 0 16px; padding-left: 4px;
  }
  .concept-ref dt { font-weight: 600; color: var(--ink); }
  .concept-ref dd { margin: 0; color: var(--muted); line-height: 1.5; }
  @media (max-width: 600px) {
    .concept-ref dl { grid-template-columns: 1fr; gap: 0 0; }
    .concept-ref dt { margin-top: 8px; }
  }

  /* ── Contact ───────────────────────────────────────────────── */
  .contact { text-align: center; padding: clamp(80px, 12vw, 140px) 0; border-top: 1px solid var(--line); }
  .contact h2 { margin-bottom: 32px; }
  .contact .channels { display: flex; gap: 28px; justify-content: center; flex-wrap: wrap; }
  .contact .channels a {
    font-size: 16px; padding: 12px 24px;
    border: 1.5px solid var(--ink); border-radius: 100px;
    transition: background 0.2s, color 0.2s;
  }
  .contact .channels a:hover { background: var(--ink); color: var(--bg); opacity: 1; }

  footer { padding: 40px 0; text-align: center; font-size: 13px; color: var(--muted); border-top: 1px solid var(--line); }

  /* ── Mobile ────────────────────────────────────────────────── */
  @media (max-width: 720px) {
    .case-card { grid-template-columns: 1fr; }
    .case-card:nth-child(even) .case-img { order: 0; }
    .about-grid, .inspiration { grid-template-columns: 1fr; }
    .inspiration-table { font-size: 12px; }
    .inspiration-table th, .inspiration-table td { padding: 6px 8px; }
    nav .links { gap: 18px; font-size: 13px; }
  }
</style>
</head>
